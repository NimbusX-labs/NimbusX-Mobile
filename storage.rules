rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Media attachments (chat files) ──────────────────────────
    // Any signed-in user can upload to the media/ folder.
    // Anyone signed-in can read (needed to display images in chat).
    match /media/{chatId}/{fileName} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 50 * 1024 * 1024; // 50 MB max
    }

    // ── User avatars ─────────────────────────────────────────────
    match /avatars/{userId}/{fileName} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024; // 5 MB max
    }

    // ── Status images ────────────────────────────────────────────
    match /status/{userId}/{fileName} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024; // 10 MB max
    }
  }
}
