rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isMember(chatData) {
      return isSignedIn() && request.auth.uid in chatData.members;
    }

    function isAdmin(chatData) {
      return isSignedIn() && chatData.admins[request.auth.uid] == true;
    }

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if request.auth.uid == userId;
      
      // Contacts subcollection
      match /contacts/{contactId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // Chats
    match /chats/{chatId} {
      allow read: if isMember(resource.data);
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.members;
      allow update: if isMember(resource.data);
      // Only group admins can delete the chat document
      allow delete: if isAdmin(resource.data);
      
      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isMember(get(/databases/$(database)/documents/chats/$(chatId)).data);
        allow create: if isMember(get(/databases/$(database)/documents/chats/$(chatId)).data) 
                      && request.resource.data.senderId == request.auth.uid;
        allow update: if isMember(get(/databases/$(database)/documents/chats/$(chatId)).data)
                      && (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']));
        // Members can delete their own messages; admins can delete any message
        allow delete: if isMember(get(/databases/$(database)/documents/chats/$(chatId)).data);
      }
    }

    // Status updates — any signed-in user can post; anyone signed-in can read
    match /statuses/{statusId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }
  }
}
